---
import { careers } from "../constants/careers";
---
    <div class="flex flex-row gap-5 items-center mt-5">
      <form
        class="flex flex-col gap-5"
        id="internships-filter"
        method="get"
      >
        <div class="flex flex-col gap-2 w-fit">
          <label for="careers">Especialidad</label>
          <select
            class="border px-3 py-1 rounded-full"
            name="careers"
            id="careers"
          >
            <option value="*">Todas</option>
            {careers.map((c) => (
              <option value={c.id}>{c.name}</option>
            ))}
          </select>
        </div>
        <div>
          <button
            class="px-4 py-1 border rounded-full"
            type="submit"
          >
            Filtrar
          </button>
        </div>
      </form>
