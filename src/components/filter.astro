        {selectedCareers.map((career) => (
          <div class="px-2 py-1 border rounded-lg w-fit flex flex-row items-center gap-5">
            <p>{career?.name}</p>
            <button onClick={() => deleteCareer(career.id)}>X</button>
          </div>
        ))}
      </div> -->
    </div>
