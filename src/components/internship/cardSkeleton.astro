---
import CareersSkeleton from "../career/careersSkeleton.astro";
---

<div class="w-full h-fit bg-light-neutral animate-pulse block text-transparent rounded-xl" aria-hidden="true">
    <article class="h-full flex flex-col gap-2 p-4">
        <!-- A.R.M line -->
        <span class=" bg-skeleton w-fit animate-pulse rounded-sm">
          A.R.M XX/XX
        </span>
        <!-- Position line -->
        <span class="text-2xl font-semibold bg-skeleton animate-pulse mb-5 mt-2 rounded-sm">
          Loading position
        </span>
        <div class="h-14 pt-5 flex flex-row gap-10 items-center justify-between">
            <span class="h-4.25 text-sm bg-skeleton animate-pulse w-fit rounded-sm" >Loading time</span>
            <!-- Careers -->
           <CareersSkeleton careers={1}/>

        </div>
    </article>
</div>