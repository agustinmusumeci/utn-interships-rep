---
import { InternshipService } from "@/services/internship.service";
import Card from "./card.astro";
import InternshipsGrid from "./internshipsGrid.astro";
import Pagination from "../pagination/pagination.astro";
import { Image } from 'astro:assets';
import notFound from '../../../public/images/pasantias-notfound.png';
import NotFound from "../404/notFound.astro";

type Props = {
    searchParams: string,
    pathname: string,
    params: {careers: Array<string> | undefined, text?:string, time?:string, date?:string, page: number}
    
}

const {searchParams, pathname, params} = Astro.props as Props;

const internshipService = new InternshipService()
const {data, pages} = await internshipService.getInternships(params) 
---
<>
    <InternshipsGrid>
        {data?.map((internship) => (
            <Card
                internship={internship}
            />
        ))}
        {
        data?.length === 0 
        && 
        <NotFound styles="col-span-full" title="Ningún resultado coincide" description="¡No te pongas nervisioso/a! Comprueba los filtros usados o prueba nuevos." action="/internships" actionLabel="Nueva búsqueda"/>
            
        }
    </InternshipsGrid>
    
    <Pagination pages={pages} page={params.page} searchParams={searchParams} pathname={pathname}/>
</>

