---
import { ArrowUpRight } from "@lucide/astro";
import Careers from "../career/careers.astro";

const {internship} = Astro.props;

---
<a class="relative h-fit w-full bg-light-neutral hover: transition-all" href={`/internships/${internship?.id}`} data-astro-prefetch>
    <div class="absolute h-1 w-20 right-0 top-0 bg-white/20"></div>
    <article class="flex flex-col gap-2 p-4">
        <div class="flex flex-row justify-between text-white/50">
            <p class="text-sm ">A.R.M {internship?.arm}</p>
            <ArrowUpRight/>
        </div>
        <div>
            <h3 class="text-2xl font-semibold mb-7 truncate line-clamp-1">{internship?.position}</h3>
            <span class="text-sm opacity-75" style={`color: ${internship.timeSinceCreated.color}`}>{internship.timeSinceCreated.time}</span>
        </div>
        <Careers careers={internship?.careers} />
    </article>
</a>
