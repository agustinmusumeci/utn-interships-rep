---
import { MapPin, House, UserRound, Building, CircleDollarSign, Share, Copy } from "@lucide/astro";
import internshipService from "../../services/internship.service";
import Careers from "../career/careers.astro";
import Linkedin from "../svg/linkedin.astro";
import X from "../svg/x.astro";
import { PLACEHOLDER } from "@/constants/placeholders";

const {id} = Astro.props;

const internship = await internshipService.getInternship(Number(id))

if (!internship) return Astro.redirect("/404");
---
<section class="mt-5 flex flex-col md:flex-row gap-5">
    <article class="flex flex-col gap-3 ">
        <div class="mb-3 flex flex-col gap-2 bg-light-neutral p-10">
            <div class="flex flex-col md:flex-row gap-0 md:gap-2 items-start md:items-center">
                <h2 class="title-lg">{internship.position}</h2>
                <span class="text-text/50 pb-5">A.R.M {internship.arm}</span>
            </div>
            <div class="mb-3">
                <Careers careers={internship?.careers}/>
            </div>
            <div class="flex flex-col md:flex-row gap-5 md:gap-10 mb-3">
                <div class="flex flex-col gap-3">
                    <p class="flex flex-row gap-2"><House class="text-text/50 w-4"/> {internship?.modality}</p>
                    <p class="flex flex-row gap-2"><MapPin class="text-text/50 w-4"/> {internship?.workplace}</p>
                    <p class="flex flex-row gap-2"><CircleDollarSign class="text-text/50 w-4"/>{typeof internship.payment === "number" ? `$${internship.payment.toLocaleString()}` : internship.payment}</p>
                </div>
                <div class="flex flex-col gap-3">
                        <p class="flex flex-row gap-2"><UserRound class="text-text/50 w-4"/> {internship?.interns} Pasante/s</p>
                        <p class="flex flex-row gap-2"><Building class="text-text/50 w-4"/> {internship.company.name}</p>
                </div>  
            </div>
            <div class="flex flex-row items-center gap-2">
                <p><span class="text-text/50 ">Publicada el </span>{new Date(internship.created_at).toLocaleDateString()}</p>
                    <span class="opacity-75 text-sm" style={`color: ${internship.timeSinceCreated.color}`}>({internship.timeSinceCreated.time})</span>
            </div>
        </div>
            
        <div class="flex flex-col gap-10 bg-light-neutral p-10">
            <div>
                <div>
                    <h3 class="title-md">Requisitos</h3>
                    <p>{internship.requirements} </p>
                </div>
                <br>
                <div>
                    <h4 class="title-sm">Conocimientos necesarios</h4>
                    <p>{internship.knowledge}</p>
                </div>
            </div>  
            <div>
                <h3 class="title-md">Horarios</h3>
                <p>Entrevista {internship.interview_timetable}</p>
                <p>Jornada {internship.timetable}</p>
            </div>
            <div>
                <h3 class="title-md">Observaciones</h3>
                <p><span class="text-text/75">Beneficios:</span> {internship.benefits}</p>
                <p><span class="text-text/75">Observaciones:</span> {internship.observations} </p>
                <p><span class="text-text/75">Referente RRHH:</span> {internship.rrhh}</p>
            </div>
            <div>
                <div class="flex flex-row gap-2 mb-10">
                    <a target="_blank" aria-disabled={internship.link === PLACEHOLDER.link} class="button button-primary" {...(internship.link !== PLACEHOLDER.link && { href: internship.link })}>
                        Solicitar
                    </a>
                    <a target="_blank" aria-disabled={internship.mail === PLACEHOLDER.mail} class="button button-outline" {...(internship.mail !== PLACEHOLDER.mail && { href: `mailto:${internship.mail}` })} >
                        Enviar Mail
                    </a>
                </div>
                <div class="text-text/50">
                    <p>Mail: {internship.mail}</p>
                    <p class="text-wrap truncate hover:underline">Link: <a {...(internship.link !== PLACEHOLDER.link && { href: internship.link })} target="_blank">{internship.link}</a></p>
                </div>
            </div>
        </div>
    </article>
    <aside class="w-full md:w-fit h-fit p-9 bg-light-neutral">
        <p class="text-lg font-bold mb-5">Comparte esta pasantía</p>
        <div class="flex flex-row gap-2">
            <button class="cursor-pointer hover:bg-neutral rounded-full px-3 py-2 transition-all" id="share-button"><Share/></button>
            <button class="cursor-pointer hover:bg-neutral rounded-full px-3 py-2 transition-all" id="clipboard-button"><Copy/></button>
            <a target="_blank" href="https://www.linkedin.com/shareArticle?mini=true&url=" class="flex items-center cursor-pointer hover:bg-neutral rounded-full px-3 py-2 transition-all"><Linkedin /></a>
            <a target="_blank" href=`https://twitter.com/intent/tweet?text=En%20%22BuscoPasantias%22%20encontre%20la%20siguiente%20oferta%20para%20universitarios!&url=` class="flex items-center cursor-pointer hover:bg-neutral rounded-full px-3 py-2 transition-all"><X /></a>
        </div>
    </aside>
</section>
<script>
    const shareButton = document.getElementById("share-button")
    const clipboardButton = document.getElementById("clipboard-button")

    shareButton?.addEventListener("click", () => {
        navigator
    .share({
        title: document.title,
        text: 'Mira esta pasantia universitaria de "BuscoPasantías"',
        url: window.location.href
    })
    .then(() => console.log('Successful share!'))
    .catch(err => console.error(err));
    })

    clipboardButton?.addEventListener("click", () => {
        navigator.clipboard.writeText(window.location.href).then(() => {
            console.log('Internship copied to clipboard');
        }).catch((err) => {
            console.error('Failed to copy: ', err);
        })
    })
    // https://www.linkedin.com/shareArticle/?mini=true&url=
</script>

