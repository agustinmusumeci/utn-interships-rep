---
import { InternshipService } from "@/services/internship.service";
import { ArrowUpRight } from "@lucide/astro";

const internshipService = new InternshipService();
const mostRecentInternships = await internshipService.getInternships({
  careers: [],
  time: "DESC",
  page: 0,
});
const threeMostRecentInternships = mostRecentInternships.data.slice(0, 3);
---

<div class="flex flex-col gap-4">
  {
    threeMostRecentInternships?.length > 0 &&
      threeMostRecentInternships?.map((internship) => (
        <a
          href={`/pasantias/${internship.id}`}
          class="flex flex-row items-center justify-between bg-light-neutral rounded-xl p-5 border border-white/20! hover:bg-neutral transition-all"
        >
          <div class="flex flex-row items-center gap-5">
            <div class="w-1 h-1 p-1 rounded-full bg-primary-hover" />

            <div>
              <span class="font-semibold line-clamp-1">
                {internship.position}
              </span>
              <div class="font-light text-sm">
                <span class="text-light-text/75">
                  {internship.company.name} • {internship.city}
                </span>
              </div>
            </div>
          </div>
          <ArrowUpRight />
        </a>
      ))
  }
</div>
