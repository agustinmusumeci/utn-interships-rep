          <h2 class="font-bold title-lg">BuscoPasantías</h2>
        </div>
    
        <nav>
          <ul class="flex flex-col md:flex-row gap-3 md:gap-6 ">
            <li><a href="/" class="nav-link">Inicio</a></li>
            <li><a href="/internships" class="nav-link">Pasantías</a></li>
