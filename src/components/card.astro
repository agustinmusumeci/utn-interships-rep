---
import Careers from "./careers.astro";

const {internship} = Astro.props;

---
<a href={`/internships/${internship.id}`} data-astro-prefetch>
    <article class={`flex flex-col gap-2 p-4 border rounded-xl`}>
        <p>A.R.M {internship.arm}</p>
        <p>{internship.position}</p>
        <Careers careers={internship.careers} />
    </article>
</a>
