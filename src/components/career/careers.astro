---
import CareerBadge from "./careerBadge.astro";

export interface CareersProps  {
    styles?: string,
    careers?: Array<{id: string, name: string, color: string, bg: string} | null>
    isCard?: boolean
}

const {styles="", careers = [], isCard = false} = Astro.props as CareersProps;

const shouldMarquee = careers.length >= 2 && isCard;
---

<div class={"overflow-hidden " + (shouldMarquee ? "marquee-wrapper " : "flex flex-row gap-2 ") + styles}>
    <div class={shouldMarquee ? "marquee-track flex flex-row gap-2" : "contents"}>
        {careers.map((career) => (
            <CareerBadge text={career?.name} color={career?.color} bg={career?.bg}/>
        ))}
        {shouldMarquee && careers.map((career) => (
            <CareerBadge text={career?.name} color={career?.color} bg={career?.bg}/>
        ))}
    </div>
    {careers.length === 0 && <CareerBadge text="Desconocida"/>}
</div>

<style>
    .marquee-wrapper {
        mask-image: linear-gradient(to right, transparent, black 12%, black 88%, transparent);
        -webkit-mask-image: linear-gradient(to right, transparent, black 12%, black 88%, transparent);
    }

    .marquee-track {
        width: max-content;
        animation: marquee 10s linear infinite;
    }

    /* Pausa al hacer hover sobre la card padre */
    :global(a:hover) .marquee-track {
        animation-play-state: paused;
    }
</style>