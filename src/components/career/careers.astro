---
import CareerBadge from "./careerBadge.astro";

export interface CareersProps  {
    styles?: string,
    careers?: Array<{id: string, name: string, color: string, bg: string} | null>
}

const {styles="", careers = []} = Astro.props as CareersProps;

---

<div class={"flex flex-row truncate gap-2 " + styles}>
    {careers.map((career) => (
       <CareerBadge text={career?.name} color={career?.color} bg={career?.bg}/>
    ))}
    {careers.length === 0 && <CareerBadge text="Desconocida"/>}
</div>