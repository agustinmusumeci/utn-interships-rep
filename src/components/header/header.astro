---
import UserTools from "./userTools.astro";
import UserToolsSkeleton from "./userToolsSkeleton.astro";
import InfoMenu from "./info-menu.tsx";
---
<header class="h-20 bg-neutral">
    <div class="container h-full flex flex-row justify-between items-center">
        <div class="flex flex-row gap-10">
            <h1 class="font-bold text-xl">
                BuscoPasantías   
            </h1>		
            <nav>
                <ul class="hidden md:flex flex-row gap-5 items-center ">
                    <li><a href="/" class="nav-link">Inicio</a></li>
                    <li><a href="/internships" class="nav-link">Pasantías</a></li>
                    <li class="relative">
                        <InfoMenu client:load />
                    </li>
                </ul>
            </nav>
        </div>
        
        <UserTools>
            <UserToolsSkeleton slot="fallback"/>
        </UserTools>
       		
    </div>
</header>