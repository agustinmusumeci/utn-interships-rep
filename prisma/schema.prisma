// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

generator zod {
  provider = "zod-prisma-types"
  output   = "./zod" // carpeta donde se generan los schemas
}

datasource db {
  provider = "postgresql"
}

model Internship {
  id                  Int     @id @default(autoincrement())
  arm                 String  @unique
  company_id          String
  university_id       String?
  city                String
  rrhh                String
  interview_timetable String
  knowledge           String
  requirements        String
  payment             Int
  timetable           String
  position            String
  benefits            String
  interns             Int
  workplace           String
  modality            String
  link                String
  mail                String?
  observations        String?
  created_at DateTime @default(now())

  Company             Company @relation(fields: [company_id], references: [id])  
  University          University? @relation(fields: [university_id], references: [id])  
  internshipCareers   InternshipCareer[]
  userNotifications   UserNotification[]
  @@index([arm], type: Hash)
}

model Career {
  id        String     @id
  name      String
  color     String
  bg        String @default("")

  internshipCareers InternshipCareer[]
  userCareers UserCareer[]
  universityCareers UniversityCareer[]
}

model University {
  id  String @id
  name String

  internships Internship[]
  careers UniversityCareer[]
}

model InternshipCareer {
  internship_id Int
  career_id     String 
  Internship    Internship @relation(fields: [internship_id], references: [id])  
  Career        Career @relation(fields: [career_id], references: [id])  

  @@id([internship_id, career_id]) 
}

model UniversityCareer {
  university_id   String
  career_id       String

  University      University @relation(fields: [university_id],references: [id])
  Career          Career @relation(fields: [career_id],references: [id])
  @@id([university_id, career_id])  
}

model Company {
  id      String @id
  name    String

  internships Internship[]
}

model User {
  id         String @id
  name       String
  mail       String
  suscripted Boolean @default(false)

  userCareers UserCareer[]
  userKeywords UserKeyword[]
  userNotifications UserNotification[]
}

model UserCareer {
  user_id   String
  career_id String

  User User @relation(fields: [user_id], references: [id])  
  Career Career @relation(fields: [career_id], references: [id])  

  @@id([user_id, career_id]) 
}

model UserKeyword { 
  user_id String 
  keyword String 
  
  User User @relation(fields: [user_id], references: [id]) 
  
  @@id([user_id, keyword]) 
}

model UserNotification {
  user_id       String
  internship_id Int
  seen          Boolean @default(false)

  User User @relation(fields: [user_id], references: [id])  
  Internship Internship @relation(fields: [internship_id], references: [id])  

  @@id([user_id, internship_id]) 
}