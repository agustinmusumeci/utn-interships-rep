// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

generator zod {
  provider = "zod-prisma-types"
  output   = "./zod" // carpeta donde se generan los schemas
}

datasource db {
  provider = "postgresql"
}

model Internship {
  id                  Int     @id @default(autoincrement())
  arm                 String  @unique
  company_id          String
  city                String
  rrhh                String
  interview_timetable String
  knowledge           String
  requirements        String
  payment             Int
  timetable           String
  position            String
  benefits            String
  interns             Int
  workplace           String
  modality            String
  link                String
  mail                String?
  observations        String?
  created_at DateTime @default(now())
  Company             Company @relation(fields: [company_id], references: [id])  

  internshipCareers InternshipCareer[]
}

model Career {
  id        String     @id
  name      String
  color     String

  internshipCareers InternshipCareer[]
}

model InternshipCareer {
  internship_id Int
  career_id    String 
  Internship Internship @relation(fields: [internship_id], references: [id])  
  Career Career @relation(fields: [career_id], references: [id])  

  @@id([internship_id, career_id]) 
}

model Company {
  id   String @id
  name String

  internships Internship[]
}